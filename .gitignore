/target
**/*.rs.bk
Cargo.lock.bak

# Harvested templates (produced by scripts/harvest_templates.py).
# Kept gitignored so we don't commit external content; regenerate with
# `python scripts/harvest_templates.py`.
/templates/manifest.json
/templates/latextemplates/
/templates/arxiv/
/templates/overleaf/

# Generated artifacts during development
*.typ.swp
*.warnings.json.swp

# Editor noise
.idea/
.vscode/
.DS_Store

# Test corpus output (harvested at build time, not source)
/tests/corpus/c*.tex
/tests/corpus/report.json

# Generated outputs from manual CLI demo runs against fixtures
/tests/fixtures/**/*.typ
/tests/fixtures/**/*.warnings.json
/tests/fixtures/**/*.pdf

# Generated outputs under templates/ are regenerated by `bytetex convert`.
/templates/**/*.typ
/templates/**/*.warnings.json
/templates/**/*.pdf

# insta pending snapshot files (transient, not source)
**/*.pending-snap
**/*.snap.new
scripts/__pycache__/
