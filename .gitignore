/target
**/*.rs.bk
Cargo.lock.bak

# Test corpus — all runtime/download artifacts.
# Inhouse source-of-truth lives in tests/inhouse/ (committed).
# Populate with: python scripts/setup_corpus.py && python scripts/harvest_templates.py
/corpus/

# Generated artifacts during development
*.typ.swp
*.warnings.json.swp

# Editor noise
.idea/
.vscode/
.DS_Store

# Test corpus output (harvested at build time, not source)
/tests/corpus/c*.tex
/tests/corpus/report.json

# Visual regression test artifacts (composites, rasterized pages, reports)
/tests/visual/

# Generated outputs from manual CLI demo runs against fixtures
/tests/fixtures/**/*.typ
/tests/fixtures/**/*.warnings.json
/tests/fixtures/**/*.pdf


# insta pending snapshot files (transient, not source)
**/*.pending-snap
**/*.snap.new
scripts/__pycache__/
scripts/output/
