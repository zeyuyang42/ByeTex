/target
**/*.rs.bk
Cargo.lock.bak

# Per-project agent state — Claude Code worktrees, plans, memory.
/.claude/

# Test corpus — manifest is committed; arXiv payloads are gitignored (large binaries).
# Fetch the regression set with: python scripts/corpus_harvest.py --pinned
# Fetch everything:              python scripts/corpus_harvest.py
/corpus/*
!/corpus/manifest.json

# Generated artifacts during development
*.typ.swp
*.warnings.json.swp

# Editor noise
.idea/
.vscode/
.DS_Store

# Test corpus output (harvested at build time, not source)
/tests/corpus/c*.tex
/tests/corpus/report.json
/tests/corpus/*.typ
/tests/corpus/*.warnings.json
/tests/corpus/*.agent_brief.md

# Generated context snapshots
/context/

# Git worktrees created at repo root
/byetex-*/

# Visual regression test artifacts (composites, rasterized pages, reports)
/tests/visual

# Generated outputs from manual CLI demo runs against fixtures
/tests/fixtures/**/*.typ
/tests/fixtures/**/*.warnings.json
/tests/fixtures/**/*.pdf


# insta pending snapshot files (transient, not source)
**/*.pending-snap
**/*.snap.new
scripts/__pycache__/
scripts/output/

# Generated by tests/input_path_resolution.rs at runtime (regenerated each run)
/crates/byetex-core/tests/fixtures/nested-input/

# Local scratch / diagnostic outputs
/tmp/

# Local release build artifacts (scripts/build_release_local.sh)
/dist/
dist_build.log

# Truth-render dependencies provisioned by scripts/setup_truth_deps.sh
/.truth-deps/
